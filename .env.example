# Copy to .env.local and fill in. All values optional while running in mock mode.

# Server API (crowdfund-server) — unused until the real backend is wired up.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Stripe publishable key (test mode: pk_test_...). Without it, /mock-checkout
# simulates the hosted checkout page.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ImgBB API key for profile/campaign image uploads. Without it, forms fall
# back to a plain image-URL input.
NEXT_PUBLIC_IMGBB_KEY=

# BetterAuth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
MONGODB_URI=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

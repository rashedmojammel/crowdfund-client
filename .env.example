# Copy to .env.local and fill in.

# crowdfund-server's URL — every API call goes through lib/api-client.ts to here.
NEXT_PUBLIC_API_URL=http://localhost:4000

# ImgBB API key for profile/campaign image uploads. Without it, forms fall
# back to a plain image-URL input.
NEXT_PUBLIC_IMGBB_KEY=

# BetterAuth — BETTER_AUTH_SECRET must be byte-for-byte identical to the
# server's copy (client signs JWTs with it, server verifies with it).
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Same MongoDB the server uses — BetterAuth writes the user collection here,
# the server reads/mutates it.
MONGODB_URI=

# Google OAuth — sign-in falls back to email/password only if these are
# blank. Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
